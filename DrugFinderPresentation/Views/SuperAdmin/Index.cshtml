@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<section class="section-steps">
    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <span class="section-label">Dashboard</span>
                <h2>System Overview</h2>
            </div>
        </div>

        <!-- Stats -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="step-card text-center">
                    <i class="fa-solid fa-store fa-2x mb-3 text-primary"></i>
                    <h4>@ViewBag.TotalPharmacies</h4>
                    <p class="text-muted">Pharmacies</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="step-card text-center">
                    <i class="fa-solid fa-users fa-2x mb-3 text-success"></i>
                    <h4>@ViewBag.TotalPatients</h4>
                    <p class="text-muted">Patients</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="step-card text-center">
                    <i class="fa-solid fa-file-medical fa-2x mb-3 text-warning"></i>
                    <h4>@ViewBag.ActiveRequests</h4>
                    <p class="text-muted">Active Requests</p>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="row g-4">
            <div class="col-md-4">
                <div class="cta-card text-center">
                    <i class="fa-solid fa-user-cog fa-2x mb-3"></i>
                    <h5>Manage Users</h5>
                    <a asp-controller="Admin" asp-action="Users" class="btn df-btn-primary mt-2">Open</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="cta-card text-center">
                    <i class="fa-solid fa-clipboard-list fa-2x mb-3"></i>
                    <h5>Monitor Requests</h5>
                    <a asp-controller="Admin" asp-action="Requests" class="btn df-btn-primary mt-2">Open</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="cta-card text-center">
                    <i class="fa-solid fa-chart-line fa-2x mb-3"></i>
                    <h5>Analytics</h5>
                    <a asp-controller="Admin" asp-action="Analytics" class="btn df-btn-primary mt-2">Open</a>
                </div>
            </div>
        </div>

    </div>
</section>