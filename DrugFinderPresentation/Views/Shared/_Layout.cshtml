<main>
    @if (TempData["Success"] != null)
    {
        <div class="alert-banner alert-banner-success">
            <div class="container d-flex align-items-center gap-3">
                <i class="fa-solid fa-circle-check fa-lg"></i>
                <span>@TempData["Success"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-banner alert-banner-error">
            <div class="container d-flex align-items-center gap-3">
                <i class="fa-solid fa-triangle-exclamation fa-lg"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    @RenderBody()
</main>

<footer class="df-footer">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-4">
                <span class="df-brand small">
                    <span class="brand-icon"><i class="fa-solid fa-capsules"></i></span>
                    Drug<strong>Finder</strong>
                </span>
            </div>
            <div class="col-md-4 text-center text-muted small">
                © @DateTime.Now.Year DrugFinder. All rights reserved.
            </div>
            <div class="col-md-4 text-end text-muted small">
                Connecting patients with nearby pharmacies
            </div>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
