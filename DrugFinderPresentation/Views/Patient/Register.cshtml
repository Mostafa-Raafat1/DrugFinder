@using DrugFinderMVC.Models
@model RegisterPatientViewModel
@{
    ViewData["Title"] = "Register as Patient";
    Layout = "_Layout";
}

<div class="df-form-page">
    <div class="container">
        <div class="df-form-card df-form-card-wide mx-auto">
            <div class="df-form-header">
                <div class="form-icon">
                    <i class="fa-solid fa-user-plus"></i>
                </div>
                <h2>Patient Registration</h2>
                <p>Create your account and start finding medications near you</p>
            </div>
            <form asp-action="Register" asp-controller="Patient" method="post" id="regForm">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <!-- Name -->
                    <div class="col-sm-6">
                        <label asp-for="FName" class="df-label">
                            <i class="fa-solid fa-user me-1 text-teal"></i> First Name
                        </label>
                        <input asp-for="FName" class="df-input" placeholder="e.g. Ahmed" />
                        <span asp-validation-for="FName" class="field-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="SName" class="df-label">Last Name</label>
                        <input asp-for="SName" class="df-input" placeholder="e.g. Hassan" />
                        <span asp-validation-for="SName" class="field-validation-error"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-12">
                        <label asp-for="Email" class="df-label">
                            <i class="fa-solid fa-envelope me-1 text-teal"></i> Email Address
                        </label>
                        <input asp-for="Email" class="df-input" type="email" placeholder="you@email.com" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <!-- Passwords -->
                    <div class="col-sm-6">
                        <label asp-for="Password" class="df-label">
                            <i class="fa-solid fa-lock me-1 text-teal"></i> Password
                        </label>
                        <input asp-for="Password" class="df-input" type="password" placeholder="Min. 6 characters" />
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="ConfirmPassword" class="df-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="df-input" type="password" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>

                    <!-- Location -->
                    <div class="col-12">
                        <label class="df-label">
                            <i class="fa-solid fa-location-dot me-1 text-teal"></i> Your Location
                        </label>
                        <div class="map-placeholder mb-2" style="border-radius:12px;">
                            <i class="fa-solid fa-map"></i>
                            <span>Set your coordinates below or use GPS detection</span>
                        </div>
                        <div class="map-coords">
                            <div class="flex-grow-1">
                                <label asp-for="Latitude" class="df-label" style="font-size:.8rem;">Latitude</label>
                                <input asp-for="Latitude" class="df-input" id="lat" type="number"
                                       step="0.000001" placeholder="e.g. 30.0444" disabled />
                                <span asp-validation-for="Latitude" class="field-validation-error"></span>
                            </div>
                            <div class="flex-grow-1">
                                <label asp-for="Longitude" class="df-label" style="font-size:.8rem;">Longitude</label>
                                <input asp-for="Longitude" class="df-input" id="lng" type="number"
                                       step="0.000001" placeholder="e.g. 31.2357" disabled />
                                <span asp-validation-for="Longitude" class="field-validation-error"></span>
                            </div>
                        </div>
                        <button type="button" id="gpsBtn"
                                style="margin-top:.6rem;width:100%;background:none;border:1.5px dashed var(--teal);
                                       color:var(--teal);border-radius:10px;padding:.55rem;font-weight:600;
                                       font-family:'Syne',sans-serif;cursor:pointer;font-size:.88rem;transition:all .2s;">
                            <i class="fa-solid fa-location-crosshairs me-1"></i> Use My Location
                        </button>
                    </div>
                </div>

                <button type="submit" class="df-btn-submit mt-4">
                    <i class="fa-solid fa-check me-2"></i>Create Patient Account
                </button>
            </form>

            <div class="form-footer-link">
                Already have an account? <a asp-controller="Account" asp-action="Login">Sign in</a>
            </div>
            <div class="form-footer-link mt-1">
                Registering a pharmacy? <a asp-controller="Pharmacy" asp-action="Register">Pharmacy sign-up →</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/patient-register.js"></script>
}

