@{
    ViewData["Title"] = "Request Submitted";
    Layout = "_Layout";
}

<div class="success-page">
    <div class="container">
        <div class="success-icon-wrap">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <h1 style="font-size:2.2rem;margin-bottom:.75rem;">Request Submitted!</h1>
        <p style="color:var(--gray-700);max-width:480px;margin:0 auto 2rem;font-size:1.05rem;">
            Your drug request has been sent. Pharmacies within <strong>3 km</strong> of your location have been notified and will respond shortly.
        </p>

        <div class="row g-3 justify-content-center mb-4" style="max-width:500px;margin:0 auto;">
            <div class="col-4">
                <div class="p-3 text-center" style="background:#f0fdf4;border-radius:14px;">
                    <i class="fa-solid fa-bell fa-lg mb-2" style="color:var(--teal);"></i>
                    <div style="font-size:.8rem;font-weight:600;color:var(--gray-700);">Pharmacies Notified</div>
                </div>
            </div>
            <div class="col-4">
                <div class="p-3 text-center" style="background:#eff6ff;border-radius:14px;">
                    <i class="fa-solid fa-clock fa-lg mb-2" style="color:#3b82f6;"></i>
                    <div style="font-size:.8rem;font-weight:600;color:var(--gray-700);">Awaiting Response</div>
                </div>
            </div>
            <div class="col-4">
                <div class="p-3 text-center" style="background:#fefce8;border-radius:14px;">
                    <i class="fa-solid fa-map-pin fa-lg mb-2" style="color:#ca8a04;"></i>
                    <div style="font-size:.8rem;font-weight:600;color:var(--gray-700);">Within 3 km</div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="DrugRequest" asp-action="Create"
               style="background:var(--teal);color:#fff;border-radius:12px;padding:.75rem 1.8rem;
                      font-weight:700;font-family:'Syne',sans-serif;text-decoration:none;
                      transition:background .2s;"
               onmouseover="this.style.background='var(--teal-dark)'"
               onmouseout="this.style.background='var(--teal)'">
                <i class="fa-solid fa-plus me-2"></i>New Request
            </a>
            <a asp-controller="Home" asp-action="Index"
               style="background:transparent;color:var(--navy);border:1.5px solid #d1d5db;
                      border-radius:12px;padding:.75rem 1.8rem;
                      font-weight:700;font-family:'Syne',sans-serif;text-decoration:none;">
                <i class="fa-solid fa-house me-2"></i>Home
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/drug-request-success.js"></script>
}
