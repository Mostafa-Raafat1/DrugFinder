@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<!-- ═══ HERO ═══ -->
<section class="df-hero">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 df-hero-content">
                <span class="df-hero-badge">
                    <i class="fa-solid fa-location-dot me-1"></i> Find Drugs Near You
                </span>
                <h1>Find Your Medicine<br><span class="hl">Faster Than Ever</span></h1>
                <p class="mt-3 mb-4">
                    DrugFinder connects patients with nearby pharmacies in real time.
                    Submit a drug request and let pharmacies respond — no phone calls, no queues.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <a asp-controller="Patient" asp-action="Register" class="df-btn-primary px-4 py-3" style="border-radius:12px;font-size:1rem;">
                            <i class="fa-solid fa-user-plus me-2"></i>Get Started Free
                        </a>
                        <a asp-controller="Account" asp-action="Login" class="df-btn-outline px-4 py-3" style="border-radius:12px;font-size:1rem;">
                            Sign In
                        </a>
                    }
                    else if (User.IsInRole("Patient"))
                    {
                        <a asp-controller="DrugRequest" asp-action="Create" class="df-btn-primary px-4 py-3" style="border-radius:12px;font-size:1rem;">
                            <i class="fa-solid fa-plus-circle me-2"></i>New Drug Request
                        </a>
                    }
                </div>
                <div class="d-flex gap-4 mt-4" style="color:rgba(255,255,255,.5);font-size:.85rem;">
                    <span><i class="fa-solid fa-shield-check me-1 text-teal"></i> Secure</span>
                    <span><i class="fa-solid fa-bolt me-1 text-teal"></i> Real-time</span>
                    <span><i class="fa-solid fa-map-pin me-1 text-teal"></i> Location-based</span>
                </div>
            </div>
            <div class="col-lg-6 df-hero-visual d-none d-lg-flex">
                <div class="hero-circle">
                    <i class="fa-solid fa-capsules hero-icon"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ HOW IT WORKS ═══ -->
<section class="section-steps">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-label">Simple Process</span>
            <h2 style="font-size:2.2rem;">How DrugFinder Works</h2>
            <p class="text-muted mt-2" style="max-width:480px;margin:auto;">
                From request to response in minutes — powered by real-time location matching.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h5>Register & Locate</h5>
                    <p>Create a patient account and share your location so we can find the nearest pharmacies to you.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h5>Submit Your Request</h5>
                    <p>List the drugs you need — name, strength, form, and quantity. Add multiple items in one request.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h5>Pharmacies Respond</h5>
                    <p>Nearby pharmacies are instantly notified and can respond with availability and pricing.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ CTA CARDS ═══ -->
<section class="section-cta">
    <div class="container">
        <div class="text-center mb-5">
            <h2>Join DrugFinder Today</h2>
            <p class="mt-2">Choose your role and start connecting.</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-5">
                <div class="cta-card">
                    <div class="cta-icon" style="color:var(--teal);">
                        <i class="fa-solid fa-person-walking-arrow-right"></i>
                    </div>
                    <h4>I'm a Patient</h4>
                    <p>Find the drugs you need from pharmacies close to you. Fast, simple, and free.</p>
                    <a asp-controller="Patient" asp-action="Register" class="btn-teal">
                        Register as Patient <i class="fa-solid fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
            <div class="col-md-5">
                <div class="cta-card">
                    <div class="cta-icon" style="color:#f4c842;">
                        <i class="fa-solid fa-store-alt"></i>
                    </div>
                    <h4>I Own a Pharmacy</h4>
                    <p>Get notified about patient drug requests near your pharmacy and grow your customer base.</p>
                    <a asp-controller="Pharmacy" asp-action="Register" class="btn-outline-white">
                        Register Pharmacy <i class="fa-solid fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a asp-controller="Account" asp-action="Login" style="color:rgba(255,255,255,.45);font-size:.9rem;text-decoration:none;">
                Already have an account? <span style="color:var(--teal);">Sign in →</span>
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/pages/home.js"></script>
}
