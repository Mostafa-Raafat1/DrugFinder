@using DrugFinderMVC.Models
@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="df-form-page">
    <div class="container">
        <div class="df-form-card mx-auto">
            <div class="df-form-header">
                <div class="form-icon">
                    <i class="fa-solid fa-key"></i>
                </div>
                <h2>Welcome Back</h2>
                <p>Sign in to your DrugFinder account</p>
            </div>

            <div asp-validation-summary="All" class="validation-summary-errors" style="display:none;"></div>

            <form asp-action="Login" method="post" id="loginForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="mb-4">
                    <label asp-for="Email" class="df-label">
                        <i class="fa-solid fa-envelope me-1 text-teal"></i> Email Address
                    </label>
                    <input asp-for="Email" class="df-input" type="email"
                           placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="df-label">
                        <i class="fa-solid fa-lock me-1 text-teal"></i> Password
                    </label>
                    <div class="position-relative">
                        <input asp-for="Password" class="df-input" type="password"
                               placeholder="Enter your password" id="pwdInput" autocomplete="current-password" />
                        <button type="button" class="btn-show-pw" id="togglePwd"
                                style="position:absolute;right:.85rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--gray-400);cursor:pointer;">
                            <i class="fa-solid fa-eye" id="pwdIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <button type="submit" class="df-btn-submit mt-2">
                    <i class="fa-solid fa-sign-in-alt me-2"></i>Sign In
                </button>
            </form>

            <div class="form-divider mt-4"><span>New to DrugFinder?</span></div>

            <div class="d-flex gap-3">
                <a asp-controller="Patient" asp-action="Register"
                   class="btn w-50 text-center"
                   style="border:1.5px solid var(--teal);color:var(--teal);border-radius:10px;font-weight:600;font-family:'Syne',sans-serif;font-size:.9rem;padding:.65rem;">
                    Patient Sign Up
                </a>
                <a asp-controller="Pharmacy" asp-action="Register"
                   class="btn w-50 text-center"
                   style="border:1.5px solid var(--navy);color:var(--navy);border-radius:10px;font-weight:600;font-family:'Syne',sans-serif;font-size:.9rem;padding:.65rem;">
                    Pharmacy Sign Up
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/login.js"></script>
}
