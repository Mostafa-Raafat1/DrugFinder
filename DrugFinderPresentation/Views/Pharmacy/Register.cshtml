@using DrugFinderMVC.Models
@model RegisterPharmacyViewModel
@{
    ViewData["Title"] = "Register Your Pharmacy";
    Layout = "_Layout";
}

<div class="df-form-page">
    <div class="container">
        <div class="df-form-card df-form-card-wide mx-auto">
            <div class="df-form-header">
                <div class="form-icon" style="background:linear-gradient(135deg,#f4c842,#e5a800);">
                    <i class="fa-solid fa-store-alt"></i>
                </div>
                <h2>Pharmacy Registration</h2>
                <p>List your pharmacy and receive real-time patient drug requests</p>
            </div>

            <div asp-validation-summary="All" class="validation-summary-errors" id="valSummary" style="display:none;"></div>

            <form asp-action="Register" asp-controller="Pharmacy" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <!-- Pharmacy Name -->
                    <div class="col-12">
                        <label asp-for="Name" class="df-label">
                            <i class="fa-solid fa-store me-1 text-teal"></i> Pharmacy Name
                        </label>
                        <input asp-for="Name" class="df-input" placeholder="e.g. Al-Nour Pharmacy" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>

                    <!-- Address -->
                    <div class="col-12">
                        <label asp-for="Address" class="df-label">
                            <i class="fa-solid fa-map-marker-alt me-1 text-teal"></i> Address
                        </label>
                        <input asp-for="Address" class="df-input" placeholder="e.g. 12 Tahrir Square, Cairo" />
                        <span asp-validation-for="Address" class="field-validation-error"></span>
                    </div>

                    <!-- Licence -->
                    <div class="col-12">
                        <label asp-for="LiscenceNumber" class="df-label">
                            <i class="fa-solid fa-id-badge me-1 text-teal"></i> Licence Number
                        </label>
                        <input asp-for="LiscenceNumber" class="df-input" placeholder="Official pharmacy licence number" />
                        <span asp-validation-for="LiscenceNumber" class="field-validation-error"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-12">
                        <label asp-for="Email" class="df-label">
                            <i class="fa-solid fa-envelope me-1 text-teal"></i> Email Address
                        </label>
                        <input asp-for="Email" class="df-input" type="email" placeholder="pharmacy@email.com" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <!-- Passwords -->
                    <div class="col-sm-6">
                        <label asp-for="Password" class="df-label">
                            <i class="fa-solid fa-lock me-1 text-teal"></i> Password
                        </label>
                        <input asp-for="Password" class="df-input" type="password" placeholder="Min. 6 characters" />
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="ConfirmPassword" class="df-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="df-input" type="password" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>

                    <!-- Location -->
                    <div class="col-12">
                        <label class="df-label">
                            <i class="fa-solid fa-location-dot me-1 text-teal"></i> Pharmacy Location
                            <span style="font-weight:400;color:var(--gray-400);font-family:'DM Sans',sans-serif;"> — used for nearby patient matching</span>
                        </label>
                        <div class="map-placeholder mb-2" style="border-radius:12px;">
                            <i class="fa-solid fa-map-pin"></i>
                            <span>Enter your pharmacy's GPS coordinates</span>
                        </div>
                        <div class="map-coords">
                            <div class="flex-grow-1">
                                <label asp-for="Latitude" class="df-label" style="font-size:.8rem;">Latitude</label>
                                <input asp-for="Latitude" class="df-input" id="lat" type="number"
                                       step="0.000001" placeholder="e.g. 30.0444" />
                                <span asp-validation-for="Latitude" class="field-validation-error"></span>
                            </div>
                            <div class="flex-grow-1">
                                <label asp-for="Longitude" class="df-label" style="font-size:.8rem;">Longitude</label>
                                <input asp-for="Longitude" class="df-input" id="lng" type="number"
                                       step="0.000001" placeholder="e.g. 31.2357" />
                                <span asp-validation-for="Longitude" class="field-validation-error"></span>
                            </div>
                        </div>
                        <button type="button" id="gpsBtn"
                                style="margin-top:.6rem;width:100%;background:none;border:1.5px dashed var(--teal);
                                       color:var(--teal);border-radius:10px;padding:.55rem;font-weight:600;
                                       font-family:'Syne',sans-serif;cursor:pointer;font-size:.88rem;transition:all .2s;">
                            <i class="fa-solid fa-location-crosshairs me-1"></i> Use My Location
                        </button>
                    </div>
                </div>

                <!-- Info notice -->
                <div class="mt-3 p-3" style="background:#fffbeb;border:1.5px solid #fde68a;border-radius:10px;">
                    <p class="mb-0" style="font-size:.85rem;color:#92400e;">
                        <i class="fa-solid fa-circle-info me-1"></i>
                        <strong>Note:</strong> After registration, you will receive notifications for drug requests submitted by patients within <strong>3 km</strong> of your pharmacy.
                    </p>
                </div>

                <button type="submit" class="df-btn-submit mt-4" style="background:linear-gradient(135deg,#0fa3b1,#0c8a97);">
                    <i class="fa-solid fa-store me-2"></i>Register My Pharmacy
                </button>
            </form>

            <div class="form-footer-link">
                Already registered? <a asp-controller="Account" asp-action="Login">Sign in</a>
            </div>
            <div class="form-footer-link mt-1">
                Are you a patient? <a asp-controller="Patient" asp-action="Register">Patient sign-up →</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/pharmacy-register.js"></script>
}
