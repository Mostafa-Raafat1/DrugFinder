@using DrugFinderPresentation.ViewModels
@model IEnumerable<RequestVM>
@{
    ViewData["Title"] = "Pharmacy Dashboard";
    Layout = "_Layout";
}

<section class="section-steps">
    <div class="container">

        <!-- Header -->
        <div class="mb-4">
            <span class="section-label">Pharmacy Panel</span>
            <h2>Incoming Requests</h2>
            <p class="text-muted">Respond to nearby patient requests instantly</p>
        </div>

        <!-- Stats Row -->
        <div class="row g-3 mb-4">
            <div class="col-4">
                <div class="dash-stat-card">
                    <div class="dash-stat-label">Pending</div>
                    <div class="dash-stat-value text-teal">@Model.Count()</div>
                </div>
            </div>
            <div class="col-4">
                <div class="dash-stat-card">
                    <div class="dash-stat-label">Responded Today</div>
                    <div class="dash-stat-value">—</div>
                </div>
            </div>
            <div class="col-4">
                <div class="dash-stat-card">
                    <div class="dash-stat-label">Rejected</div>
                    <div class="dash-stat-value" style="color:var(--coral)">—</div>
                </div>
            </div>
        </div>

        <!-- Request Cards -->
        <div class="row g-4">
            @foreach (var req in Model)
            {
                var initials = string.Concat(req.PatientName
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(w => w[0]));

                <div class="col-md-6">
                    <div class="req-card">
                        <!-- Teal top bar via CSS -->

                        <div class="req-card-top">
                            <div class="patient-row">
                                <div class="patient-avatar">@initials</div>
                                <div>
                                    <div class="patient-name">@req.PatientName</div>
                                    <div class="patient-time">@req.CreatedAt.ToString("MMM d, h:mm tt")</div>
                                </div>
                            </div>
                            <span class="dist-badge">@req.DistanceKm.ToString("0.#") km</span>
                        </div>

                        <div class="req-divider"></div>

                        <ul class="drug-list">
                            @foreach (var drug in req.Drugs)
                            {
                                <li class="drug-row">
                                    <div>
                                        <div class="drug-name">@drug.Name</div>
                                        <div class="drug-meta">
                                            @(drug.Strength != null ? drug.Strength : "")
                                            @(drug.Form != null ? "· " + drug.Form : "")
                                        </div>
                                    </div>
                                    <span class="drug-qty">×@drug.Quantity</span>
                                </li>
                            }
                        </ul>

                        <div class="req-actions">
                            <a asp-action="Respond" asp-controller="Pharmacy" asp-route-id="@req.Id" class="btn-req-respond">
                                ✓ Respond
                            </a>
                            <a asp-action="Reject" asp-controller="Pharmacy" asp-route-id="@req.Id" class="btn-req-reject">
                                ✕ Reject
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

    </div>
</section>