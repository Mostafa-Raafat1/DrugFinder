@using DrugFinderPresentation.ViewModels
@model IEnumerable<RequestVM>

@{
    ViewData["Title"] = "Pharmacy Dashboard";
    Layout = "_Layout";
}

<section class="section-steps">
    <div class="container">

        <!-- Header -->
        <div class="mb-5">
            <span class="section-label">Pharmacy Panel</span>
            <h2>Incoming Requests</h2>
            <p class="text-muted">Respond to nearby patient requests instantly</p>
        </div>

        <!-- Requests -->
        <div class="row g-4">
            @foreach (var req in Model)
            {
                <div class="col-md-6">
                    <div class="step-card">
                        <h5>@req.PatientName</h5>
                        <p class="text-muted small">@req.CreatedAt</p>

                        <ul class="mb-3">
                            @foreach (var drug in req.Drugs)
                            {
                                <li>@drug.Name - @drug.Quantity</li>
                            }
                        </ul>

                        <div class="d-flex gap-2">
                            <a asp-action="Respond" asp-route-id="@req.Id"
                               class="btn df-btn-primary btn-sm">
                                Respond
                            </a>

                            <a asp-action="Reject" asp-route-id="@req.Id"
                               class="btn btn-outline-danger btn-sm">
                                Reject
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

    </div>
</section>